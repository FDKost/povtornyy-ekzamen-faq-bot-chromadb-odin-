# Environment variables for the FAQ bot

# MCP API key for LLM and embeddings
MCP_API_KEY=your_mcp_api_key_here

# MCP model names
MCP_CHAT_MODEL=anthropic/claude-3-5-sonnet-20240620
MCP_EMBEDDINGS_MODEL=cohere/embed-english-v3

# Path to store ChromaDB data
CHROMA_DB_PATH=./chromadb

# Optional: maximum number of documents to retrieve
MAX_RETRIEVAL_DOCS=5
